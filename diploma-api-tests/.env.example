# Base URL where Wekan is available.
# For your current docker-compose setup, this is usually http://localhost (port 80).
BASE_URL=http://localhost

# Use either WEKAN_USERNAME or WEKAN_EMAIL.
WEKAN_USERNAME=
WEKAN_EMAIL=
WEKAN_PASSWORD=

# Optional second test user (used for permissions/authorization functional tests).
# Use either WEKAN_USERNAME_2 or WEKAN_EMAIL_2.
WEKAN_USERNAME_2=
WEKAN_EMAIL_2=
WEKAN_PASSWORD_2=

# HTTP request timeout.
REQUEST_TIMEOUT_SECONDS=20
